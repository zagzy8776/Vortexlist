generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  ADMIN
}

enum ProductCategory {
  PROXY
  PHONE_NUMBER
  ESIM
}

enum OrderStatus {
  PENDING
  PAID
  FULFILLING
  FULFILLED
  FAILED
  CANCELLED
  REFUNDED
}

enum WalletTransactionType {
  DEPOSIT
  PURCHASE
  REFUND
  ADMIN_CREDIT
  ADMIN_DEBIT
}

enum DepositStatus {
  PENDING
  VERIFIED
  FAILED
  CANCELLED
}

enum SupportTicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

model User {
  id           String              @id @default(cuid())
  name         String?
  email        String              @unique
  passwordHash String?
  role         UserRole            @default(USER)
  wallet       Wallet?
  orders       Order[]
  deposits     WalletDeposit[]
  supportTickets SupportTicket[]
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
}

model Wallet {
  id           String              @id @default(cuid())
  userId       String              @unique
  user         User                @relation(fields: [userId], references: [id])
  currency     String              @default("NGN")
  balanceKobo  Int                 @default(0)
  transactions WalletTransaction[]
  deposits     WalletDeposit[]
}

model WalletTransaction {
  id          String                @id @default(cuid())
  walletId    String
  wallet      Wallet                @relation(fields: [walletId], references: [id])
  type        WalletTransactionType
  amountKobo  Int
  reference   String?
  description String?
  createdAt   DateTime              @default(now())
}

model WalletDeposit {
  id              String        @id @default(cuid())
  userId          String
  user            User          @relation(fields: [userId], references: [id])
  walletId        String
  wallet          Wallet        @relation(fields: [walletId], references: [id])
  amountKobo      Int
  currency        String        @default("NGN")
  status          DepositStatus @default(PENDING)
  reference       String        @unique
  authorizationUrl String?
  providerMeta    Json?
  verifiedAt      DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model Country {
  id       String    @id @default(cuid())
  name     String
  isoCode  String    @unique
  products Product[]
}

model Provider {
  id        String    @id @default(cuid())
  name      String    @unique
  slug      String    @unique
  enabled   Boolean   @default(true)
  products  Product[]
  createdAt DateTime  @default(now())
}

model Product {
  id              String          @id @default(cuid())
  name            String
  category        ProductCategory
  providerId      String?
  provider        Provider?       @relation(fields: [providerId], references: [id])
  countryId       String?
  country         Country?        @relation(fields: [countryId], references: [id])
  providerCostUsd Decimal         @default(0)
  markupPercent   Decimal         @default(30)
  fixedMarkupUsd  Decimal         @default(0)
  active          Boolean         @default(true)
  orders          OrderItem[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

model Order {
  id           String       @id @default(cuid())
  userId       String
  user         User         @relation(fields: [userId], references: [id])
  status       OrderStatus  @default(PENDING)
  totalKobo    Int
  providerMeta Json?
  items        OrderItem[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id])
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int     @default(1)
  priceKobo Int
}

model SupportTicket {
  id        String              @id @default(cuid())
  userId    String
  user      User                @relation(fields: [userId], references: [id])
  subject   String
  message   String
  status    SupportTicketStatus @default(OPEN)
  adminNote String?
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
}